# ─── AI provider ──────────────────────────────────────────────────────────────
# AI_PROVIDER selects which backend to use: "groq" or "ollama".
# If unset, "groq" is used when GROQ_API_KEY is present, otherwise "ollama".
AI_PROVIDER=groq

# Groq Cloud (recommended for hosted/serverless demos — laptop-independent)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local / tunneled Ollama (only used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# ─── Data + app ───────────────────────────────────────────────────────────────
DATASET_PATH=../Dataset for Disease Tracking_HDS.xlsx
DB_PATH=./ap_health.db
FRONTEND_URL=http://localhost:8080
